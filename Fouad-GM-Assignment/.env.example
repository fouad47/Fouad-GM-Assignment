# ============================================
# Environment Configuration for Fouad-GM-Assignment
# ============================================
# Copy this file as .env and fill in your values

# Base URL for the application under test
BASE_URL=https://demoqa.com

# API Base URL
API_BASE_URL=https://demoqa.com

# Browser settings
HEADLESS=true
BROWSER=chromium

# Timeout settings (in milliseconds)
DEFAULT_TIMEOUT=30000
EXPECT_TIMEOUT=10000

# Retry configuration
RETRY_COUNT=1

# Parallel workers
WORKERS=4

# Reporting
REPORT_DIR=reports

# API credentials (used for API tests)
API_USERNAME=testuser_fouad
API_PASSWORD=Test@12345678
